{
  "name": "template-react-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5175",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:pages": "tsc -p tsconfig.json --noEmit && vite build && node scripts/prepare-pages.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 5175",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "smoke": "playwright test --config=e2e/playwright.config.cjs"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@gjxwxt/react-components": "^0.4.1",
    "@gjxwxt/react-style-base": "^0.2.1",
    "antd": "^5.29.2",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@types/react": "^16.14.66",
    "@types/react-dom": "^16.9.25",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.8.2",
    "vite": "^4.5.5"
  },
  "packageManager": "pnpm@10.32.1"
}
